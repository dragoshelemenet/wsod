generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Brand {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  logoUrl         String?
  coverImageUrl   String?
  description     String?
  seoTitle        String?
  metaDescription String?
  isVisible       Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  mediaItems      MediaItem[]
}

model PersonModel {
  id               String      @id @default(cuid())
  name             String
  slug             String      @unique
  portraitImageUrl String?
  description      String?
  seoTitle         String?
  metaDescription  String?
  isVisible        Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  mediaItems       MediaItem[]
}

model AudioProfile {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  kind            String
  coverImageUrl   String?
  description     String?
  seoTitle        String?
  metaDescription String?
  isVisible       Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  mediaItems      MediaItem[]
}

model MediaItem {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  category         String
  type             String
  date             DateTime
  thumbnailUrl     String?
  previewUrl       String?
  fileUrl          String?
  fileNameOriginal String?
  description      String?
  seoTitle         String?
  metaDescription  String?

  groupLabel       String?
  groupOrder       Int      @default(0)
  sortOrder        Int      @default(0)
  graphicKind      String?
  isFeatured       Boolean  @default(false)
  isVisible        Boolean  @default(true)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  brandId          String?
  brand            Brand?        @relation(fields: [brandId], references: [id], onDelete: Cascade)

  personModelId    String?
  personModel      PersonModel?  @relation(fields: [personModelId], references: [id], onDelete: Cascade)

  audioProfileId   String?
  audioProfile     AudioProfile? @relation(fields: [audioProfileId], references: [id], onDelete: Cascade)

  blogPostMedia    BlogPostMedia[]

  @@index([category])
  @@index([brandId])
  @@index([personModelId])
  @@index([audioProfileId])
  @@index([groupLabel])
  @@index([graphicKind])
}

model BlogPost {
  id              String         @id @default(cuid())
  title           String
  slug            String         @unique
  excerpt         String?
  contentHtml     String
  seoTitle        String?
  metaDescription String?
  coverImageUrl   String?
  status          String         @default("draft")
  publishedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  mediaLinks      BlogPostMedia[]

  @@index([status])
  @@index([publishedAt])
}

model BlogPostMedia {
  id          String   @id @default(cuid())
  blogPostId  String
  mediaItemId String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  blogPost    BlogPost  @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, mediaItemId])
  @@index([blogPostId])
  @@index([mediaItemId])
}

model SiteSectionVisibility {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteContent {
  id               String   @id
  servicesEyebrow  String?
  servicesTitle    String?
  servicesList     String?
  servicesCards    String?
  packageCards     String?
  pricingLabel     String?
  pricingHref      String?
  contactLabel     String?
  contactHref      String?
  claimLabel       String?
  claimHref        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
