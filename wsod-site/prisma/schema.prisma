generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Brand {
  id         String      @id @default(cuid())
  name       String
  slug       String      @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  mediaItems MediaItem[]
}

model MediaItem {
  id          String   @id @default(cuid())
  title       String
  category    String
  type        String
  date        DateTime
  thumbnail   String?
  fileUrl     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brandId String
  brand   Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
}